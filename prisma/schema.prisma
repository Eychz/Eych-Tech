generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CUSTOMER
}

enum TokenType {
  VERIFY_EMAIL
  RESET_PASSWORD
}

enum ProductCategory {
  LAPTOP
  PHONE
  PAD
}

enum ProductAvailability {
  AVAILABLE
  PENDING
  SOLD
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      Role     @default(CUSTOMER)
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages  Message[]
}

model OtpToken {
  id        String    @id @default(cuid())
  email     String
  token     String
  expiresAt DateTime
  type      TokenType
}

model Product {
  id            String   @id @default(cuid())
  title         String
  subtitle      String?
  description   String
  price         Decimal
  condition     String
  batteryHealth String?
  storage       String?
  variant       String?
  images        String[]
  category      ProductCategory     @default(PHONE)
  availability  ProductAvailability @default(AVAILABLE)
  isFeatured    Boolean             @default(false)
  createdAt     DateTime            @default(now())
  deletedAt     DateTime?

  messages      Message[]
}

model ChatRoom {
  id        String   @id @default(cuid())
  guestId   String   @unique  // UUID stored in guest's localStorage
  guestName String   @default("Guest") // Short display label e.g. "Guest-8f3a"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages  Message[]
}

model Message {
  id         String   @id @default(cuid())
  chatRoomId String
  senderId   String?  // Admin's userId (null for guest messages)
  guestId    String?  // Guest UUID (null for admin messages)
  productId  String?  // Associated product ID for item inquiries
  isAdmin    Boolean  @default(false)
  text       String
  createdAt  DateTime @default(now())

  chatRoom   ChatRoom @relation(fields: [chatRoomId], references: [id])
  sender     User?    @relation(fields: [senderId], references: [id])
  product    Product? @relation(fields: [productId], references: [id])
}

model ProofOfTransaction {
  id          String   @id @default(cuid())
  title       String
  description String
  imageUrl    String
  createdAt   DateTime @default(now())
}
